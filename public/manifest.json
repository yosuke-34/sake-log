{
  "name": "酒ログ - お酒の記録帳",
  "short_name": "酒ログ",
  "description": "飲んだお酒を記録するアプリ",
  "start_url": "/",
  "display": "standalone",
  "background_color": "#FAF5EF",
  "theme_color": "#C53D43",
  "orientation": "portrait",
  "icons": [
    {
      "src": "/icon-192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any maskable"
    },
    {
      "src": "/icon-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any maskable"
    }
  ],
  "share_target": {
    "action": "/add?shared=1",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "title": "title",
      "text": "text",
      "files": [
        {
          "name": "photo",
          "accept": ["image/png", "image/jpeg", "image/gif", "image/webp", "image/*"]
        }
      ]
    }
  }
}
